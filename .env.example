# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-supabase-publishable-key"

# ── Groq AI (https://console.groq.com) ───────────────────────────────────────
VITE_GROQ_API_KEY="your-groq-api-key"

# ── OpenRouteService (https://openrouteservice.org) ───────────────────────────
VITE_ORS_API_KEY="your-ors-api-key"

# ── Amadeus (https://developers.amadeus.com) ──────────────────────────────────
VITE_AMADEUS_API_KEY="your-amadeus-api-key"
VITE_AMADEUS_API_SECRET="your-amadeus-api-secret"

# ── OpenTripMap (https://opentripmap.io) ──────────────────────────────────────
VITE_OPENTRIPMAP_API_KEY="your-opentripmap-api-key"

# ── TomTom Traffic (https://developer.tomtom.com) ────────────────────────────
VITE_TRAFFIC_API_KEY="your-tomtom-api-key"

# ── Mappls / MapMyIndia (https://apis.mappls.com) ─────────────────────────────
VITE_MAPPLS_FRONTEND_KEY="your-mappls-frontend-key"
VITE_MAPPLS_BACKEND_KEY="your-mappls-backend-key"
